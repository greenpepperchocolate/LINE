# Django バックエンド環境変数 (backend/.env にコピーして使う)

# 本番では必ずランダムな値に変更
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# 管理画面 (Next.js) のオリジン。カンマ区切りで複数指定可
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# --- LINE 連携 ---
# Messaging API のトークン/シークレット (メッセージ送信・署名検証に使用)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Cloudflare Workers 中継 (apps/webhook-relay) → Django webhook を認証する共有シークレット。
# 中継 Worker の RELAY_SHARED_SECRET と必ず同じ値にする。
RELAY_SHARED_SECRET=dev-relay-secret-change-me
