# Django バックエンド環境変数 (backend/.env にコピーして使う)

# 本番では必ずランダムな値に変更
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# 管理画面 (Next.js) のオリジン。カンマ区切りで複数指定可
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# --- LINE 連携 ---
# Messaging API のトークン/シークレット (メッセージ送信・署名検証に使用)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Cloudflare Workers 中継 (apps/webhook-relay) → Django webhook を認証する共有シークレット。
# 中継 Worker の RELAY_SHARED_SECRET と必ず同じ値にする。
RELAY_SHARED_SECRET=dev-relay-secret-change-me

# --- 画像ストレージ (Cloudflare R2 / S3 互換) ---
# 下記をすべて設定すると R2 を使用。未設定なら backend/media/ にローカル保存。
R2_BUCKET=line-harness-images
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 公開URL (R2 public bucket / 独自ドメイン)。設定時は画像配信をそこへリダイレクト。
# 例: https://images.example.com  または  https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
